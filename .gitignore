# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# App data (local dev)
data/

# Cursor terminals
terminals/

# Terraform — never commit state, secrets, or local overrides
infra/.terraform/
infra/.terraform.lock.hcl
infra/*.tfstate
infra/*.tfstate.*
infra/*.tfstate.backup
infra/terraform.tfvars
infra/*.auto.tfvars
infra/override.tf
infra/override.tf.json
infra/*_override.tf
infra/*_override.tf.json
infra/crash.log
infra/crash.*.log
infra/*.pem
infra/*.pub
infra/.terraform.tfstate.lock.info

# Any terraform anywhere (defense in depth)
**/.terraform/
**/*.tfstate*
**/*_override.tf*

# Secrets / credentials (never leak)
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
aws-credentials
.aws/
supabase.env
*.tfvars
!*.tfvars.example
!terraform.tfvars.example

# Note: infra/ *code* is committed (public Terraform), but state + tfvars + keys are ignored above.
# The Python package (PyPI) only includes the "app" module thanks to pyproject.toml — infra never ships in wheels.