# =============================================================================
# Transcribe Studio — Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# --- App ---
TRANSCRIBE_STUDIO_HOST=0.0.0.0
TRANSCRIBE_STUDIO_PORT=8082
TRANSCRIBE_STUDIO_DATA=/var/lib/transcribe-studio

# --- Supabase (cloud database backup) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_URL=postgresql://postgres.your-project-id:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- AWS S3 (audio & transcript storage) ---
# If running on EC2 with an IAM role, you can skip ACCESS_KEY and SECRET_KEY
S3_BUCKET=your-transcribe-studio-bucket
S3_PREFIX=transcribe-studio
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...        # Not needed on EC2 with IAM role
# AWS_SECRET_ACCESS_KEY=...        # Not needed on EC2 with IAM role
